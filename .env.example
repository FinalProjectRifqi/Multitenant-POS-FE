# =============================================================================
# .env.example — Multitenant POS Frontend (Next.js)
#
# Copy file ini ke .env dan isi semua nilai.
#   cp .env.example .env
#
# Variabel backend (DB, JWT, Midtrans, dll.) ada di .env.example
# di repo multitenant-pos-be.
# =============================================================================


# =============================================================================
# GENERAL
# =============================================================================

# Tag image Docker (default: latest)
IMAGE_TAG=latest

# Loki URL (untuk logging — isi jika sudah setup Loki)
# LOKI_URL=http://your-loki-host:3100

# Traefik certresolver — sesuaikan dengan nama certresolver di traefik.yml kamu
# Gunakan "cloudflare" jika domain rifqifzn.my.id ada di Cloudflare account yang sama
# Gunakan "letsencrypt" jika butuh certresolver HTTP-01 terpisah
TRAEFIK_CERTRESOLVER=cloudflare


# =============================================================================
# FRONTEND (Next.js)
# =============================================================================

FE_PORT=3000

# Domain publik FE — dipakai Traefik untuk routing
DOMAIN_FE=multitenant-pos.rifqifzn.my.id

# NextAuth v5 — Generate dengan: openssl rand -base64 32
AUTH_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_32

# Public URL aplikasi frontend (digunakan NextAuth untuk callback URL)
AUTH_URL=https://pos.yourdomain.com

# URL backend API — pakai nama Docker service via pos-network (internal)
# FE dan BE harus bergabung ke network yang sama (pos-network).
# Ganti ke public URL BE hanya jika tidak pakai shared Docker network.
API_BASE_URL=http://backend:3004

# Feature flags (baked ke JS bundle saat build time; juga dibaca server-side)
NEXT_PUBLIC_AUTH_MODE=real
NEXT_PUBLIC_INVENTARIS_MODE=real

# =============================================================================
# BUILD-TIME ONLY: NEXT_PUBLIC_* vars di bawah ini di-inline ke JS bundle
# saat `next build`. Harus tersedia sebagai build args di Dockerfile.
# Nilai default sudah di-set di Dockerfile dan docker-compose.yml sesuai
# seed database. Hanya perlu di-isi jika UUID database-mu berbeda.
# =============================================================================

# Order status UUIDs — sesuai seed data database.
# UUID ini fixed (tidak berubah setelah seed). Override hanya jika perlu.
# NEXT_PUBLIC_JUST_IN_ORDER_STATUS_ID=e7f281a6-22cb-4f7c-ad6e-0588996515f4
# NEXT_PUBLIC_ON_PROCESS_ORDER_STATUS_ID=4df54409-695e-4fef-b519-46608ac9e0a5
# NEXT_PUBLIC_READY_ORDER_STATUS_ID=5b6b821f-6fc3-469c-9a2a-f0ffbef05a80
# NEXT_PUBLIC_COMPLETE_ORDER_STATUS_ID=044b4c5b-a8c0-45e8-b00d-8ecbaec2ba68
# NEXT_PUBLIC_CANCEL_ORDER_STATUS_ID=365894dd-f81b-435f-b19b-44cae066f351

# Simulate Midtrans payment success — WAJIB false di production
# Set ke "true" hanya untuk development/demo lokal
NEXT_PUBLIC_SIMULATE_PAYMENT_SUCCESS=false
